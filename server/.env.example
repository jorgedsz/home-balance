# Postgres connection string (Railway: copy from the Postgres add-on's Connect tab)
DATABASE_URL="postgresql://user:password@host:port/dbname"

# Single password used by the login screen. Pick anything strong.
APP_PASSWORD="change-me"

# Random string for signing JWTs. Generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-random-string"

# Server port (Railway will set this automatically)
PORT=5000
